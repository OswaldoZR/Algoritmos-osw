###############################################################################
# Normalize line endings automatically
###############################################################################
* text=auto

###############################################################################
# Python source files
###############################################################################
*.py text

###############################################################################
# GraphViz files
###############################################################################
*.gv text
*.dot text

###############################################################################
# Markdown documentation
###############################################################################
*.md text

###############################################################################
# Images (binary)
###############################################################################
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.svg binary

###############################################################################
# PDF documents
###############################################################################
*.pdf binary